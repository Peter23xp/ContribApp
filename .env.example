# ══════════════════════════════════════════════
# CONTRIBUTAPP RDC — Variables d'Environnement
# ══════════════════════════════════════════════

# ENVIRONNEMENT
# 'development' = SQLite local + sandbox agrégateur
# 'production'  = Firestore + agrégateur live
EXPO_PUBLIC_ENV=development

# BASE DE DONNÉES
# true  = utiliser SQLite local (développement)
# false = utiliser Firestore (production)
EXPO_PUBLIC_USE_LOCAL_DB=true

# ── FIREBASE ─────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── CLOUDFLARE R2 ────────────────────────────
EXPO_PUBLIC_CF_ACCOUNT_ID=
EXPO_PUBLIC_CF_BUCKET_NAME=contributapp-rdc
EXPO_PUBLIC_CF_PUBLIC_URL=https://pub-XXXXX.r2.dev
EXPO_PUBLIC_CF_WORKER_URL=https://contributapp-storage.YOUR_SUBDOMAIN.workers.dev

# ── AGRÉGATEUR DE PAIEMENT ──────────────────
# 'flexpay' ou 'serdipay'
EXPO_PUBLIC_AGGREGATOR=flexpay

# FlexPay (RDC)
EXPO_PUBLIC_FLEXPAY_TOKEN=
EXPO_PUBLIC_FLEXPAY_MERCHANT=

# SerdiPay (RDC) — alternative
EXPO_PUBLIC_SERDIPAY_KEY=
