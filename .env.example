# ══════════════════════════════════════════════════════
# CONTRIBUTAPP RDC — Variables d'Environnement v2.0
# ══════════════════════════════════════════════════════
# IMPORTANT : Ce fichier est un template sans valeurs.
# Créez .env.local avec vos vraies valeurs (jamais committé sur Git)
#
# SQLite supprimé — Firebase est l'unique source de données.

# ENVIRONNEMENT
# 'development' = projet Firebase de test + sandbox
# 'production'  = projet Firebase production
EXPO_PUBLIC_ENV=development

# ── FIREBASE ──────────────────────────────────────────
# Obtenir depuis : console.firebase.google.com → Paramètres du projet
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── CLOUDFLARE R2 ──────────────────────────────────────
# Obtenir depuis : dash.cloudflare.com → R2 → Votre bucket
EXPO_PUBLIC_CF_ACCOUNT_ID=
EXPO_PUBLIC_CF_BUCKET_NAME=contributapp-rdc
EXPO_PUBLIC_CF_PUBLIC_URL=https://pub-XXXXX.r2.dev
# URL du Worker Cloudflare qui signe les uploads
EXPO_PUBLIC_CF_WORKER_URL=https://contributapp-storage.YOUR_SUBDOMAIN.workers.dev

# ── GOOGLE GEMINI ──────────────────────────────────────
# Obtenir depuis : aistudio.google.com → API Keys
# Modèle utilisé : gemini-1.5-flash (analyse captures de paiement)
EXPO_PUBLIC_GEMINI_API_KEY=

# ── AGRÉGATEUR DE PAIEMENT (RÉSERVÉ USAGE FUTUR) ──────
# Non utilisé — le paiement est manuel (Gemini + trésorière)
# Décommenter quand l'intégration FlexPay sera active
# EXPO_PUBLIC_AGGREGATOR=flexpay
# EXPO_PUBLIC_FLEXPAY_TOKEN=
# EXPO_PUBLIC_FLEXPAY_MERCHANT=
