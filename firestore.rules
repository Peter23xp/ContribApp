rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Un utilisateur ne peut lire/modifier que son propre profil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Les membres d'un groupe peuvent lire le groupe
    // Seul l'admin peut modifier
    match /groups/{groupId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        resource.data.admin_uid == request.auth.uid;

      // Sous-collection membres
      match /members/{memberId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if request.auth != null && 
          get(/databases/$(database)/documents/groups/$(groupId)).data.admin_uid == request.auth.uid;
      }
    }

    // Contributions : lecture par membres du groupe, écriture par le membre concerné
    match /contributions/{contributionId} {
      allow read: if request.auth != null && 
        (resource.data.member_uid == request.auth.uid || 
         exists(/databases/$(database)/documents/groups/$(resource.data.group_id)/members/$(request.auth.uid)));
      allow create: if request.auth != null && request.auth.uid == request.resource.data.member_uid;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.member_uid || 
         get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.admin_uid == request.auth.uid);
    }

    // Notifications : chaque utilisateur ne lit que les siennes
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && 
        resource.data.recipient_uid == request.auth.uid;
    }
  }
}
